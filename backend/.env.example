# Server
PORT=5001
# Comma-separated; must include the Next.js origin (see frontend package.json dev port)
CORS_ORIGIN=http://localhost:5050,http://localhost:5000,http://localhost:5002

# Supabase — get from: https://supabase.com/dashboard/project/<ref>/settings/api
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...   # anon/public key (JWT format)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...  # service_role key — NEVER expose to frontend

# Auth — generate with: openssl rand -base64 32
JWT_SECRET=replace-with-strong-random-secret
JWT_EXPIRES_IN=30d

# QR signing — generate with: openssl rand -base64 32
QR_SECRET=replace-with-strong-random-secret
QR_TOKEN_TTL_MINUTES=10
